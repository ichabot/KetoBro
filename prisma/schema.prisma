generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Basisdaten
  height        Float?    // cm
  gender        String?   // male, female, diverse
  birthDate     DateTime?
  activityLevel String?   // sedentary, light, moderate, active, very_active

  // KI-Einstellungen
  llmProvider      String?   // claude | local
  anthropicApiKey  String?   // verschlüsselt
  llmEndpoint      String?   // URL für lokales LLM
  llmModel         String?   // Modellname

  // Ziele
  goalWeight       Float?    // kg Zielgewicht
  goalCalories     Int?      // kcal Tagesziel
  goalNetCarbs     Int?      // g max Netto-Carbs
  goalProtein      Int?      // g Protein Tagesziel

  // UI Preferences
  darkMode         Boolean   @default(false)

  // Relations
  measurements  Measurement[]
  vitals        Vitals[]
  nutritionDays NutritionDay[]
  chatMessages  ChatMessage[]
  favorites     FavoriteProduct[]

  // Rate limiting
  lastChatAt    DateTime?
  chatCount     Int       @default(0)
  chatCountReset DateTime?
}

model Measurement {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())

  weight    Float    // kg
  waist     Float?   // cm
  thigh     Float?   // cm
  arm       Float?   // cm

  @@index([userId, date])
}

model Vitals {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp     DateTime @default(now())

  systolic      Int?
  diastolic     Int?
  bloodGlucose  Float?
  bloodKetones  Float?
  urineKetones  Float?

  @@index([userId, timestamp])
}

// Tagescontainer für Ernährung
model NutritionDay {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date

  // Berechnete Tagessummen (Cache)
  totalCalories      Float  @default(0)
  totalProtein       Float  @default(0)
  totalFat           Float  @default(0)
  totalCarbs         Float  @default(0)
  totalFiber         Float  @default(0)
  totalNetCarbs      Float  @default(0)
  skaldemanRatio     Float?

  meals     MealEntry[]

  @@unique([userId, date])
  @@index([userId, date])
}

// Einzelne Mahlzeit/Eintrag
model MealEntry {
  id              String       @id @default(cuid())
  nutritionDayId  String
  nutritionDay    NutritionDay @relation(fields: [nutritionDayId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())

  mealType        String       // breakfast | lunch | dinner | snack
  productName     String?      // Name des Produkts
  barcode         String?      // OFF Barcode
  portionGrams    Float?       // Portionsgröße

  calories        Float
  protein         Float
  fat             Float
  carbs           Float
  fiber           Float
  netCarbs        Float

  @@index([nutritionDayId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())

  role      String   // user | assistant
  content   String

  @@index([userId, timestamp])
}

model FavoriteProduct {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  barcode   String
  name      String
  brand     String?
  image     String?

  // Nährwerte pro 100g
  caloriesPer100g  Float
  proteinPer100g   Float
  fatPer100g       Float
  carbsPer100g     Float
  fiberPer100g     Float

  @@unique([userId, barcode])
  @@index([userId])
}
